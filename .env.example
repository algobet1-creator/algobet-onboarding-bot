# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/algobet_bot

# Telegram User ID of the admin (get it from @userinfobot)
ADMIN_CHAT_ID=123456789

# The private channel ID (negative number, e.g. -1001234567890)
# Tip: forward a message from your channel to the bot after startup to auto-detect it
CHANNEL_ID=-1001234567890

# Optional: Node environment
NODE_ENV=production
